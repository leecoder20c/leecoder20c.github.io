{
    "files.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/.next": true,
        "**/build": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/.next": true,
        "**/build": true
    },
    "files.watcherExclude": {
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/.next/**": true,
        "**/build/**": true
    },
    "liveSassCompile.settings.generateMap": false,
    "liveSassCompile.settings.formats":[
        {
            "format": "expanded",
            "extensionName": ".css",
            "savePath": "/css"
        }
    ],
    "liveSassCompile.settings.autoprefix": [
        "> 1%",
        "last 2 versions",
        "cover 99.5%"
    ],
    "liveSassCompile.settings.excludeList": [
        "**/node_modules/**",
        ".vscode/**",
        "**/dist/**"
    ],
    "liveServer.settings.port": 5775,
    "liveServer.settings.root": "/dist",
    "compile-hero.disable-compile-files-on-did-save-code": true
}
